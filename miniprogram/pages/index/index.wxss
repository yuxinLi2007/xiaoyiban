/** index.wxss — 老人端首页「今日提醒」 **/

page {
  padding-top: 54rpx;
  background-color: #f5f5f5;
  padding-bottom: 60rpx;
}

.container {
  padding: 0 32rpx;
  font-family: PingFang SC, Microsoft YaHei, sans-serif;
  min-height: 100vh;
}

/* 加载状态 */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}
.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #e0e0e0;
  border-top-color: #07C160;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
.loading-text {
  margin-top: 20rpx;
  font-size: 30rpx;
  color: #999;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* 页面头部 */
.page-header {
  margin-bottom: 36rpx;
}

.greeting {
  font-size: 34rpx;
  color: #666;
  margin-bottom: 12rpx;
}

/* 页面标题 — 大号适老 */
.page-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #1a1a1a;
}

/* 提醒卡片 — 白色圆角 */
.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

/* 健康小贴士卡片 — 纵向排列 */
.card.card-tip {
  flex-direction: column;
  align-items: stretch;
}

/* 卡片左侧文字区域 */
.card-body {
  flex: 1;
  display: flex;
  align-items: center;
  margin-right: 20rpx;
}

.card.card-tip .card-body {
  margin-right: 0;
  margin-bottom: 4rpx;
}

/* 卡片图标 */
.card-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

/* 卡片文字 */
.card-text {
  flex: 1;
}

/* 卡片标题 */
.card-title {
  font-size: 38rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

/* 卡片副标题 */
.card-subtitle {
  font-size: 34rpx;
  color: #888888;
}

/* 卡片右侧操作区 */
.card-action {
  flex-shrink: 0;
}

/* 我吃过了按钮 — 橙色 */
.btn-taken {
  width: 220rpx;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #FF6B35;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: none;
  padding: 0;
}
.btn-taken::after {
  border: none;
}

/* 已服用标签 — 绿色 */
.taken-label {
  font-size: 34rpx;
  color: #07C160;
  font-weight: 500;
  white-space: nowrap;
}

/* 别忘啦标签 — 红色 */
.remind-tag {
  font-size: 30rpx;
  color: #FA5151;
  background: #fde8e8;
  padding: 10rpx 24rpx;
  border-radius: 10rpx;
  white-space: nowrap;
}

/* 分享今日提醒给子女按钮 */
.share-tip-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #07C160;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: none;
  text-align: center;
  margin-top: 24rpx;
}
.share-tip-btn::after {
  border: none;
}
