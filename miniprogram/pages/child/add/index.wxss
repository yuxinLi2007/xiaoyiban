.page {
  padding: 32rpx;
  background-color: #f5f6f8;
  min-height: 100vh;
}

.form-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 12rpx 36rpx 36rpx;
  box-shadow: 0 6rpx 32rpx rgba(0, 0, 0, 0.05);
}

.form-item {
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f0f0f3;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 30rpx;
  color: #8c8c9a;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  font-size: 34rpx;
  color: #1a1a2e;
  padding: 18rpx 24rpx;
  background: #f5f6f8;
  border-radius: 16rpx;
}

.form-input.picker {
  color: #4a7cf7;
  font-weight: 600;
}

.submit-btn {
  margin-top: 48rpx;
  background: linear-gradient(135deg, #4a7cf7, #6c5ce7);
  color: #fff;
  font-size: 38rpx;
  font-weight: 700;
  border-radius: 24rpx;
  height: 108rpx;
  line-height: 108rpx;
  border: none;
  letter-spacing: 8rpx;
}

.submit-btn::after {
  border: none;
}
