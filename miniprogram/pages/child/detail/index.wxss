.page {
  padding: 0 32rpx 40rpx;
  background-color: #F5F7FA;
  min-height: 100vh;
}

/* ========== 加载状态 ========== */
.state-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  gap: 24rpx;
}

.spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid #e8e8e8;
  border-top-color: #1A9E75;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* ========== 错误状态 / 空状态 ========== */
.state-error {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  gap: 16rpx;
  padding: 48rpx;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.error-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.error-hint {
  font-size: 26rpx;
  color: #999;
  text-align: center;
}

.btn-retry {
  margin-top: 32rpx;
  background-color: #1A9E75;
  color: #fff;
  font-size: 28rpx;
  border-radius: 44rpx;
  padding: 16rpx 48rpx;
  border: none;
}

.btn-retry::after {
  display: none;
}

/* ========== 诊断标题区 ========== */
.diag-header {
  background: #1A9E75;
  margin: 0 -32rpx;
  padding: 56rpx 48rpx 48rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.diag-patient {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.85);
  background: rgba(255, 255, 255, 0.18);
  align-self: flex-start;
  padding: 4rpx 20rpx;
  border-radius: 16rpx;
  margin-bottom: 8rpx;
}

.diag-title {
  font-size: 52rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.3;
}

.diag-time {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 4rpx;
}

/* ========== 信息分块 ========== */
.section {
  display: flex;
  align-items: flex-start;
  background: #fff;
  border-radius: 20rpx;
  padding: 36rpx 32rpx;
  margin-top: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.section-icon {
  font-size: 44rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
  padding-top: 2rpx;
}

.section-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.section-label {
  font-size: 26rpx;
  color: #999;
}

.section-value {
  font-size: 34rpx;
  color: #1a1a2e;
  font-weight: 500;
  line-height: 1.6;
}

/* ========== 就诊总结 ========== */
.summary-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 36rpx 32rpx;
  margin-top: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  border-left: 6rpx solid #1A9E75;
}

.summary-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.summary-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.summary-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A9E75;
}

.summary-text {
  font-size: 30rpx;
  color: #333;
  line-height: 1.8;
}

/* ========== 底部操作栏 ========== */
.detail-footer {
  margin-top: 48rpx;
  padding-bottom: 40rpx;
}

.btn-back {
  width: 100%;
  background-color: #1A9E75;
  color: #fff;
  font-size: 30rpx;
  border-radius: 44rpx;
  padding: 24rpx 0;
  border: none;
  font-weight: 600;
}

.btn-back::after {
  display: none;
}
