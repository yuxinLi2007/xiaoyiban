.container { padding: 32rpx; background: #f5f5f5; min-height: 100vh; }
.page-title { font-size: 48rpx; font-weight: bold; margin-bottom: 32rpx; }
.info-bar { display: flex; align-items: baseline; margin-bottom: 16rpx; }
.dept { font-size: 40rpx; font-weight: bold; color: #1a1a1a; margin-right: 20rpx; }
.doctor { font-size: 40rpx; color: #1a1a1a; }
.status { font-size: 28rpx; display: inline-block; padding: 6rpx 24rpx; border-radius: 10rpx; margin-bottom: 24rpx; }
.status-done { color: #07C160; background: #e8f8ef; }
.status-pending { color: #ff9500; background: #fff3e0; }
.hospital, .time { font-size: 34rpx; color: #555; margin-bottom: 16rpx; }
.elder-name { font-size: 34rpx; color: #555; margin-bottom: 24rpx; }
.summary-card, .transcript-card { background: #fff; border-radius: 20rpx; padding: 36rpx 32rpx; margin-bottom: 28rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06); }
.summary-title { font-size: 36rpx; font-weight: bold; margin-bottom: 20rpx; color: #1a1a1a; }
.summary-content { font-size: 34rpx; color: #333; line-height: 1.7; }
.transcript-content { font-size: 30rpx; color: #666; line-height: 1.5; white-space: pre-wrap; }
.empty-tip { text-align: center; padding: 60rpx 0; color: #999; font-size: 30rpx; }

/* 加载状态 */
.loading-wrap { display: flex; flex-direction: column; align-items: center; justify-content: center; padding-top: 200rpx; }
.loading-spinner { width: 60rpx; height: 60rpx; border: 6rpx solid #e0e0e0; border-top-color: #07C160; border-radius: 50%; animation: spin 0.8s linear infinite; }
.loading-text { margin-top: 20rpx; font-size: 30rpx; color: #999; }
@keyframes spin { to { transform: rotate(360deg); } }

/* 家人语音播报按钮 */
.voice-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #FF6B35;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: none;
  padding: 0 32rpx;
  box-sizing: border-box;
  margin-top: 20rpx;
  transition: background-color 0.3s;
}
.voice-btn::after {
  border: none;
}
.voice-btn[disabled] {
  opacity: 0.9;
}

/* loading 状态：颜色变化 + 脉冲动画 */
.voice-btn.loading {
  background-color: #e85d2a;
  animation: voicePulse 1s ease-in-out infinite;
}

@keyframes voicePulse {
  0%   { transform: scale(1); }
  50%  { transform: scale(1.04); background-color: #d94f1e; }
  100% { transform: scale(1); }
}
