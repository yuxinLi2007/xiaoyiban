<view class="page">

  <!-- ====== 第一层：loading ====== -->
  <view class="state-loading" wx:if="{{loading}}">
    <view class="spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- ====== 第二层：未登录 ====== -->
  <view class="state-login" wx:elif="{{!isLoggedIn}}">
    <view class="login-card">
      <view class="login-icon">
        <text class="icon-t">医</text>
      </view>
      <text class="login-title">请先登录</text>
      <text class="login-desc">登录后可查看家人健康信息与就诊记录</text>
      <button class="btn-primary" bindtap="goLogin">去登录</button>
    </view>
  </view>

  <!-- ====== 第三层：已登录 ====== -->
  <block wx:else>

    <!-- 顶部问候区 -->
    <view class="header">
      <view class="header-left">
        <text class="header-title">您好</text>
        <text class="header-sub">关心家人健康，从每一次就诊开始</text>
      </view>
      <view class="notify-btn" bindtap="goList">
        <text class="bell-text">通知</text>
        <view class="red-dot" wx:if="{{totalUnread > 0}}"></view>
      </view>
    </view>

    <!-- 统计卡片 -->
    <view class="stats-row" wx:if="{{elders.length > 0}}">
      <view class="stat-card">
        <text class="stat-num">{{elders.length}}</text>
        <text class="stat-label">家人</text>
      </view>
      <view class="stat-card">
        <text class="stat-num">{{totalUnread}}</text>
        <text class="stat-label">未读记录</text>
      </view>
      <view class="stat-card stat-highlight" bindtap="goList">
        <text class="stat-action">查看全部 ›</text>
      </view>
    </view>

    <!-- 区块标题 -->
    <view class="section-header">
      <text class="section-title">家人健康</text>
    </view>

    <!-- 家人卡片列表 -->
    <view class="elder-list" wx:if="{{elders.length > 0}}">
      <view
        class="elder-card {{item.unreadCount > 0 ? 'card-unread' : ''}}"
        wx:for="{{elders}}"
        wx:key="_id"
        bindtap="goElderDetail"
        data-id="{{item._id}}">

        <!-- 左侧绿条（未读） -->
        <view class="card-bar" wx:if="{{item.unreadCount > 0}}"></view>

        <view class="card-body">

          <!-- 头部：名字 + 状态标签 + 未读数 -->
          <view class="card-top">
            <view class="card-name-row">
              <view class="avatar-circle">
                <text class="avatar-char">{{item.gender === '男' ? '男' : '女'}}</text>
              </view>
              <text class="card-name">{{item.name}}</text>
              <text class="tag tag-{{item.statusTag}}">{{item.statusText}}</text>
            </view>
            <view class="unread-pill" wx:if="{{item.unreadCount > 0}}">
              <text class="unread-num">{{item.unreadCount}} 条新消息</text>
            </view>
          </view>

          <!-- 最新记录摘要 -->
          <view class="card-summary" wx:if="{{item.latestRecord}}">
            <view class="summary-row">
              <text class="summary-label">最新诊断</text>
              <text class="summary-value">{{item.latestRecord.diagnosis || '-'}}</text>
            </view>
            <view class="summary-row">
              <text class="summary-label">就诊日期</text>
              <text class="summary-value">{{item.latestRecord.date || '-'}}</text>
            </view>
          </view>
          <view class="card-summary-empty" wx:else>
            <text>暂无就诊记录，点击添加</text>
          </view>

          <!-- 底部操作 -->
          <view class="card-footer">
            <text class="footer-link">查看全部记录 ></text>
            <text class="footer-count">共 {{item.recordCount || 0}} 条</text>
          </view>

        </view>
      </view>
    </view>

    <!-- 无数据兜底 -->
    <view class="empty-state" wx:else>
      <view class="empty-icon">
        <text class="empty-emoji">📋</text>
      </view>
      <text class="empty-main">暂无家人信息</text>
      <text class="empty-sub">添加家人后即可管理健康数据</text>
      <button class="btn-primary btn-sm" bindtap="goAddElder">添加家人</button>
    </view>

  </block>

</view>
