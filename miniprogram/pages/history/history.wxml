<!-- pages/history/history.wxml -->
<view class="container">
  <!-- 顶部大标题 -->
  <view class="page-title">历史记录</view>

  <!-- 加载状态 -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:elif="{{records.length > 0}}">
    <!-- 记录列表 -->
    <view class="card" wx:for="{{records}}" wx:key="id">
      <view class="card-header">
        <view class="dept-name">{{item.department}}</view>
        <view class="doctor-name">{{item.doctor}}</view>
      </view>
      <view class="status-badge {{item.status === '已完成' ? 'done' : 'pending'}}">{{item.status}}</view>
      <view class="hospital">就诊医院：{{item.hospital}}</view>
      <view class="time">{{item.date}}</view>
      <view class="diagnosis" wx:if="{{item.diagnosis}}">诊断：{{item.diagnosis}}</view>
      <view class="source-tag" wx:if="{{item.source === 'child'}}">子女代录</view>
      <view class="summary-link" bindtap="goToDetail" data-id="{{item.id}}">查看就诊摘要 ›</view>
      <view class="card-divider"></view>
    </view>
  </block>

  <!-- 空状态 -->
  <view class="empty-state" wx:else>
    <view class="empty-icon">📋</view>
    <view class="empty-text">暂无记录，去录音吧</view>
    <button class="go-record-btn" bindtap="goToRecord">去录音</button>
  </view>
</view>
