/** history.wxss **/

page {
  padding-top: 54rpx;
  background-color: #f5f5f5;
  padding-bottom: 60rpx;
}

.container {
  padding: 0 32rpx;
  font-family: PingFang SC, Microsoft YaHei, sans-serif;
}

/* 页面标题 — 大号适老 */
.page-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 36rpx;
}

/* 就诊卡片 — 与首页保持一致 */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

/* 卡片头部 */
.card-header {
  display: flex;
  align-items: baseline;
  margin-bottom: 12rpx;
}
.dept-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-right: 20rpx;
}
.doctor-name {
  font-size: 38rpx;
  color: #333333;
}

/* 状态标签 */
.status-badge {
  display: inline-block;
  font-size: 28rpx;
  color: #07C160;
  background: #e8f8ef;
  padding: 6rpx 24rpx;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
}

/* 医院和时间 */
.hospital,
.time {
  font-size: 34rpx;
  color: #555555;
  margin-bottom: 12rpx;
}

/* 查看就诊摘要链接 */
.summary-link {
  font-size: 34rpx;
  color: #07C160;
  padding: 16rpx 0;
  margin-top: 8rpx;
}

/* 卡片底部浅色分割线 */
.card-divider {
  height: 2rpx;
  background-color: #f0f0f0;
  margin-top: 28rpx;
}

/* 空状态容器 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-top: 200rpx;
}

/* 空状态图标 */
.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

/* 空状态提示文字 */
.empty-text {
  font-size: 38rpx;
  color: #999999;
  margin-bottom: 48rpx;
}

/* 去录音按钮 — 绿色大按钮 */
.go-record-btn {
  width: 320rpx;
  height: 96rpx;
  line-height: 96rpx;
  background-color: #07C160;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 500;
  border-radius: 48rpx;
  border: none;
  text-align: center;
}
.go-record-btn::after {
  border: none;
}
