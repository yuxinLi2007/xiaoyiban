<view class="page">
  <view class="header-area">
    <text class="brand-title">我的小医陪</text>
    <text class="brand-subtitle">关心家人健康，从每一次就诊开始</text>
  </view>

  <view class="main-card">
    <!-- 头像 -->
    <view class="avatar-box">
      <image
        wx:if="{{avatarUrl}}"
        src="{{avatarUrl}}"
        class="avatar-img"
        mode="aspectFill"
      />
      <view wx:else class="avatar-ph">
        <text class="ph-char">人</text>
      </view>
    </view>
    <button
      class="pick-avatar-btn"
      open-type="chooseAvatar"
      bindchooseavatar="onChooseAvatar"
    >{{ avatarUrl ? '更换头像' : '设置头像' }}</button>

    <text class="card-hint">登录后查看家人健康数据与就诊记录</text>

    <button
      class="login-btn {{busy ? 'busy' : ''}}"
      disabled="{{busy}}"
      bindtap="doLogin"
    >{{ busy ? '登录中...' : '微信一键登录' }}</button>
  </view>

  <view class="agreement">
    <text class="agree-text">登录即表示同意</text>
    <text class="agree-link">《用户协议》</text>
    <text class="agree-text">和</text>
    <text class="agree-link">《隐私政策》</text>
  </view>
</view>
