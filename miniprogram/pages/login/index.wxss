.page {
  min-height: 100vh;
  background: #F5F7FA;
}

.header-area {
  padding: 120rpx 40rpx 0;
}
.brand-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #222;
  letter-spacing: 2rpx;
}
.brand-subtitle {
  display: block;
  font-size: 27rpx;
  color: #999;
  margin-top: 12rpx;
  line-height: 1.5;
}

.main-card {
  margin: 56rpx 36rpx 0;
  background: #fff;
  border-radius: 20rpx;
  padding: 52rpx 40rpx 44rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
}

.avatar-box {
  display: flex;
  justify-content: center;
  margin-bottom: 12rpx;
}
.avatar-img {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
}
.avatar-ph {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: #f0f2f5;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #ddd;
}
.ph-char { font-size: 44rpx; color: #bbb; font-weight: 600; }

.pick-avatar-btn {
  display: block;
  margin: 0 auto 36rpx;
  font-size: 24rpx;
  color: #1A9E75;
  background: transparent !important;
  border: none !important;
  padding: 6rpx 20rpx;
  line-height: 1.5;
}
.pick-avatar-btn::after { border: none; }

.card-hint {
  display: block;
  text-align: center;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 36rpx;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  background: #1A9E75;
  color: #fff;
  font-size: 31rpx;
  font-weight: 600;
  text-align: center;
  border: none !important;
  box-shadow: 0 6rpx 20rpx rgba(26,158,117,0.25);
}
.login-btn::after { border: none; }
.login-btn.busy,
.login-btn[disabled] { opacity: 0.55; }

.agreement {
  position: fixed;
  bottom: 56rpx;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
}
.agree-text { font-size: 22rpx; color: #ccc; }
.agree-link { font-size: 22rpx; color: #999; }
