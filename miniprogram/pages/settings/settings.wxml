<!-- pages/settings/settings.wxml -->
<view class="container">
  <!-- 顶部大标题 -->
  <view class="page-title">我的</view>

  <!-- 设备管理 -->
  <view class="section">
    <view class="section-title">设备管理</view>
    <!-- 绑定子女设备 — 可点击弹出提示 -->
    <view class="setting-item" bindtap="bindDevice">
      <text>绑定子女设备</text>
      <text class="arrow">›</text>
    </view>
    <view class="setting-item">
      <text>当前设备ID</text>
      <text class="value">XiaoYi-001</text>
    </view>
  </view>

  <!-- 消息推送 -->
  <view class="section">
    <view class="section-title">消息推送</view>
    <view class="setting-item">
      <text>微信接收就诊提醒</text>
      <switch checked="{{pushEnabled}}" bindchange="togglePush"/>
    </view>
  </view>

  <!-- 关于 -->
  <view class="section">
    <view class="section-title">关于</view>
    <view class="setting-item">
      <text>版本</text>
      <text class="value">1.0.0</text>
    </view>
  </view>

  <!-- 底部版本号 -->
  <view class="footer-version">小医伴 v1.0.0</view>
</view>
