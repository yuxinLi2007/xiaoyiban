.page {
  min-height: 100vh;
  background: #F7F5FB;
}

/* ====== Tabs ====== */
.tabs-scroll {
  background: #F7F5FB;
  padding: 20rpx 32rpx 0;
  white-space: nowrap;
}
.tabs-wrap { display: inline-flex; gap: 16rpx; }

.tab-item {
  display: inline-block;
  font-size: 27rpx;
  color: #999;
  background: #fff;
  padding: 14rpx 32rpx;
  border-radius: 32rpx;
  font-weight: 500;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
  flex-shrink: 0;
}
.tab-active {
  background: #5A4A7A;
  color: #fff;
}

/* ====== 列表 ====== */
.record-list {
  display: flex;
  flex-direction: column;
  padding: 24rpx 32rpx 40rpx;
  gap: 20rpx;
}

/* ====== 卡片 ====== */
.record-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 28rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  position: relative;
  overflow: hidden;
}
.record-card:active { opacity: 0.9; }

/* ====== 微信风格红点（核心：简洁、左上角、无动画）===== */
.red-dot {
  position: absolute;
  top: 24rpx;
  left: 24rpx;
  width: 14rpx;
  height: 14rpx;
  background: #FF4D4F;
  border-radius: 50%;
}

/* 卡片头部 */
.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  margin-left: 8rpx;
}
.patient-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}
.card-date { font-size: 24rpx; color: #999; }

/* 诊断 */
.card-diagnosis {
  margin-bottom: 18rpx;
  margin-left: 8rpx;
}
.diag-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 信息分层 */
.info-section {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 18rpx 8rpx;
  border-top: 1rpx solid #f0f0f0;
  border-bottom: 1rpx solid #f0f0f0;
}
.info-item {
  display: flex;
  align-items: center;
}
.info-label {
  font-size: 24rpx;
  color: #999;
  min-width: 96rpx;
  flex-shrink: 0;
}
.info-val {
  font-size: 26rpx;
  color: #333;
  flex: 1;
}

/* 底部 */
.card-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 18rpx;
  margin-left: 8rpx;
}
.source-tag {
  font-size: 22rpx;
  color: #bbb;
  background: #f5f5f5;
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
}
.foot-link {
  font-size: 26rpx;
  color: #576B95;
  font-weight: 500;
}

/* ====== 加载态 ====== */
.loading-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 50vh;
  gap: 16rpx;
}
.spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #e8e8e8;
  border-top-color: #5A4A7A;
  border-radius: 50%;
  animation: spin 0.75s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { font-size: 26rpx; color: #999; }

/* ====== 空状态 ====== */
.empty-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}
.empty-icon-text { font-size: 64rpx; margin-bottom: 16rpx; }
.empty-title { font-size: 30rpx; font-weight: 600; color: #333; margin-bottom: 8rpx; }
.empty-hint { font-size: 26rpx; color: #bbb; }
