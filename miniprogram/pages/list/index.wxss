.page {
  min-height: 100vh;
  background: #F5F7FA;
}

/* ====== Tabs ====== */
.tabs-scroll {
  background: #F5F7FA;
  padding: 20rpx 32rpx 0;
  white-space: nowrap;
}
.tabs-wrap { display: inline-flex; gap: 16rpx; }

.tab-item {
  display: inline-block;
  font-size: 27rpx;
  color: #888;
  background: #fff;
  padding: 14rpx 32rpx;
  border-radius: 32rpx;
  font-weight: 500;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
  flex-shrink: 0;
}
.tab-active {
  background: #1A9E75;
  color: #fff;
  box-shadow: 0 4rpx 14rpx rgba(26,158,117,0.25);
}

/* ====== 列表 ====== */
.record-list {
  display: flex;
  flex-direction: column;
  padding: 24rpx 32rpx 40rpx;
  gap: 20rpx;
}

/* ====== 卡片 ====== */
.record-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 28rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
  position: relative;
  overflow: hidden;
}
.record-card:active { opacity: 0.94; }

/* 未读红点 */
.new-dot {
  position: absolute;
  top: 22rpx;
  right: 22rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #FF4D4F;
}
/* 未读左侧绿条 */
.card-new::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 8rpx;
  background: #1A9E75;
  border-radius: 20rpx 0 0 20rpx;
}

/* 卡片头部 */
.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.head-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  overflow: hidden;
}
.patient-name {
  font-size: 27rpx;
  font-weight: 600;
  color: #2B7FDD;
  background: rgba(43,127,221,0.07);
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}
.card-date { font-size: 24rpx; color: #999; flex-shrink: 0; margin-left: 12rpx; }

/* 标签系统 */
.tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
  font-weight: 600;
  flex-shrink: 0;
}
.tag-pending { color: #FA8C16; background: rgba(250,140,22,0.08); }
.tag-review { color: #FA8C16; background: rgba(250,140,22,0.1); }
.tag-done { color: #1A9E75; background: rgba(26,158,117,0.08); }

/* 诊断 */
.card-diagnosis {
  margin-bottom: 18rpx;
}
.diag-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #222;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 信息分层 */
.info-section {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 18rpx 0;
  border-top: 1rpx solid #f0f2f5;
  border-bottom: 1rpx solid #f0f2f5;
}
.info-item {
  display: flex;
  align-items: center;
}
.info-label {
  font-size: 24rpx;
  color: #999;
  min-width: 110rpx;
  flex-shrink: 0;
}
.info-val {
  font-size: 27rpx;
  color: #444;
  flex: 1;
}

/* 底部 */
.card-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 18rpx;
}
.source-tag {
  font-size: 22rpx;
  color: #bbb;
  background: #f7f8fa;
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
}
.foot-link {
  font-size: 27rpx;
  color: #1A9E75;
  font-weight: 600;
}

/* ====== 空状态 ====== */
.empty-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}
.empty-icon-text { font-size: 64rpx; margin-bottom: 16rpx; }
.empty-title { font-size: 30rpx; font-weight: 600; color: #333; margin-bottom: 8rpx; }
.empty-hint { font-size: 26rpx; color: #bbb; }
