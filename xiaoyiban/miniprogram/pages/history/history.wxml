<!-- pages/history/history.wxml -->
<view class="container">
  <!-- 顶部大标题 -->
  <view class="page-title">历史记录</view>

  <!-- 记录列表 -->
  <block wx:for="{{records}}" wx:key="id">
    <view class="card">
      <view class="card-header">
        <view class="dept-name">{{item.deptName}}</view>
        <view class="doctor-name">{{item.doctorName}}</view>
      </view>
      <view class="status-badge">{{item.status}}</view>
      <view class="hospital">就诊医院：{{item.hospitalName}}</view>
      <view class="time">{{item.visitTime}}</view>
      <view class="summary-link" bindtap="goToDetail" data-id="{{item.id}}">查看就诊摘要 ›</view>
      <view class="card-divider"></view>
    </view>
  </block>

  <!-- 空状态：无记录时友好提示 + 跳转录音页按钮 -->
  <view class="empty-state" wx:if="{{records.length === 0}}">
    <view class="empty-icon">📋</view>
    <view class="empty-text">暂无记录，去录音吧</view>
    <button class="go-record-btn" bindtap="goToRecord">去录音</button>
  </view>
</view>
