/* pages/record/record.wxss */
.page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background: #f5f5f5;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 80rpx;
}

.record-btn {
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  background-color: #07C160;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 40rpx;
  transition: 0.2s;
}

.record-btn.active {
  background-color: #FA5151;
}

.tip {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.tip.done {
  color: #07C160;
}

.bottom-btns {
  display: flex;
  gap: 30rpx;
  margin-top: 60rpx;
}

.btn-secondary, .btn-primary {
  width: 200rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
}

.btn-secondary {
  background: #fff;
  border: 2rpx solid #ddd;
}

.btn-primary {
  background: #07C160;
  color: #fff;
}