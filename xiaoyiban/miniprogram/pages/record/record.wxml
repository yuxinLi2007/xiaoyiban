<!-- pages/record/record.wxml -->
<view class="page">
  <view class="title">录音</view>

  <!-- 巨大录音按钮 -->
  <view class="record-btn {{isRecording ? 'active' : ''}}" bindtap="toggleRecord">
    <text>{{buttonText}}</text>
  </view>

  <!-- 提示文字 -->
  <view class="tip" wx:if="{{!isRecording && buttonText === '点击开始录音'}}">
    录音时请尽量靠近手机讲话
  </view>
  <view class="tip done" wx:elif="{{!isRecording && buttonText === '录音完成'}}">
    录音完成
  </view>

  <!-- 底部操作按钮组 -->
  <view class="bottom-btns" wx:if="{{audioPath}}">
    <button class="btn-secondary" bindtap="playAudio">播放录音</button>
    <button class="btn-primary" bindtap="finishRecord">完成录音</button>
  </view>
</view>