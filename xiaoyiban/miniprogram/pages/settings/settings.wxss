/** settings.wxss **/

page {
  padding-top: 54rpx;
  background-color: #f5f5f5;
  padding-bottom: 60rpx;
}

.container {
  padding: 0 32rpx;
  font-family: PingFang SC, Microsoft YaHei, sans-serif;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 页面标题 — 大号适老 */
.page-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 36rpx;
}

/* 区块卡片 */
.section {
  background: #ffffff;
  border-radius: 20rpx;
  margin-bottom: 28rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

/* 区块标题 */
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #888888;
  padding: 24rpx 32rpx 0;
}

/* 设置项 — 适老大高度 */
.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx;
  font-size: 38rpx;
  color: #333333;
  border-bottom: 1rpx solid #f0f0f0;
  min-height: 88rpx;
}
.setting-item:last-child {
  border-bottom: none;
}

/* 箭头 */
.arrow {
  font-size: 44rpx;
  color: #cccccc;
}

/* 值文本 */
.value {
  color: #999999;
  font-size: 34rpx;
}

/* 底部版本号 */
.footer-version {
  text-align: center;
  font-size: 28rpx;
  color: #cccccc;
  margin-top: auto;
  padding: 60rpx 0 40rpx;
}
