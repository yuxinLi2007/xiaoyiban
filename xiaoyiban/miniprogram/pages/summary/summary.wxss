.container { padding: 32rpx; background: #f5f5f5; min-height: 100vh; }
.page-title { font-size: 48rpx; font-weight: bold; margin-bottom: 32rpx; }
.info-bar { display: flex; align-items: baseline; margin-bottom: 16rpx; }
.dept { font-size: 40rpx; font-weight: bold; color: #1a1a1a; margin-right: 20rpx; }
.doctor { font-size: 40rpx; color: #1a1a1a; }
.status { font-size: 28rpx; color: #07C160; background: #e8f8ef; display: inline-block; padding: 6rpx 24rpx; border-radius: 10rpx; margin-bottom: 24rpx; }
.hospital, .time { font-size: 34rpx; color: #555; margin-bottom: 16rpx; }
.summary-card, .transcript-card { background: #fff; border-radius: 20rpx; padding: 36rpx 32rpx; margin-bottom: 28rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06); }
.summary-title { font-size: 36rpx; font-weight: bold; margin-bottom: 24rpx; }
.summary-content { font-size: 34rpx; color: #333; line-height: 1.6; }
.transcript-content { font-size: 30rpx; color: #666; line-height: 1.5; white-space: pre-wrap; }
